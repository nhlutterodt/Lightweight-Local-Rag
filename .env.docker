# Docker policy overrides for reproducible local-dev.
# Use with: docker compose --env-file .env.docker up --build

# Pin service image to immutable digest.
OLLAMA_IMAGE=ollama/ollama@sha256:719122581b6932e1240ae70d788859089cb80d17e23cd4f98ba960b0290f70cb

# Pin client runtime base image used in gui/client/react-client/Dockerfile.
NGINX_IMAGE=nginx:1.27-alpine@sha256:65645c7bb6a0661892a8b03b89d0743208a18dd2f3f17a54ef4b76fb8e2f2a10

# Model bootstrap policy.
OLLAMA_HOST=ollama:11434
OLLAMA_MODELS=nomic-embed-text llama3.1:8b
OLLAMA_MAX_RETRIES=60
OLLAMA_RETRY_SECONDS=2
OLLAMA_PULL_RETRIES=5
