exports[`visual regression harness > chat recovery states render consistently in dark theme > chat-recovery-dark 1`] = `
<div
  aria-busy="false"
  aria-label="Conversation history"
  aria-live="polite"
  aria-relevant="additions text"
  class="chat-window"
  id="chatWindow"
  role="log"
>
  <div
    class="message user-message glass"
  >
    <div
      class="content"
    >
      <div
        class="message-header"
      >
        <h3>
          You
        </h3>
        <time
          class="message-time"
          datetime="2026-03-16T10:00:00.000Z"
        >
          3/16/2026, 6:00:00 AM
        </time>
      </div>
      <div
        class="message-markdown"
      >
        <p>
          Explain token strategy
        </p>
      </div>
    </div>
  </div>
  <div
    class="message ai-message glass"
  >
    <div
      class="content"
    >
      <div
        class="message-header"
      >
        <h3>
          System
        </h3>
        <time
          class="message-time"
          datetime="2026-03-16T10:00:02.000Z"
        >
          3/16/2026, 6:00:02 AM
        </time>
      </div>
      <div
        class="message-markdown"
      >
        <p>
          Partial answer
        </p>
      </div>
      <div
        class="message-recovery status-interrupted"
        role="alert"
      >
        <p
          class="message-recovery-title"
        >
          Response interrupted
        </p>
        <p
          class="message-recovery-detail"
        >
          Stream interrupted.
        </p>
        <div
          class="message-recovery-actions"
        >
          <button
            class="btn-secondary message-recovery-button"
            type="button"
          >
            Retry response
          </button>
        </div>
      </div>
    </div>
  </div>
  <div
    class="message ai-message glass"
  >
    <div
      class="content"
    >
      <div
        class="message-header"
      >
        <h3>
          System
        </h3>
        <time
          class="message-time"
          datetime="2026-03-16T10:00:03.000Z"
        >
          3/16/2026, 6:00:03 AM
        </time>
      </div>
      <div
        class="error-badge"
        role="alert"
      >
        Backend unavailable.
      </div>
    </div>
  </div>
  <div
    aria-hidden="true"
  />
</div>
`;

