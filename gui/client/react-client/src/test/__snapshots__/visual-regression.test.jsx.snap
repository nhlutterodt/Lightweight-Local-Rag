// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`visual regression harness > analytics status surfaces render consistently in dark theme > analytics-status-dark 1`] = `
<section
  aria-labelledby="indexMonitorLabel"
  class="nav-item"
>
  <span
    class="field-label"
    id="indexMonitorLabel"
  >
    Vector Index Monitor
  </span>
  <p
    aria-atomic="true"
    aria-live="polite"
    class="sr-only"
    role="status"
  >
    2 vector indices loaded.
  </p>
  <div
    aria-describedby="indexMonitorSummary"
    class="index-monitor-box"
    id="indexMonitor"
  >
    <div
      class="panel-state-summary"
      id="indexMonitorSummary"
    >
      2 vector indices loaded.
    </div>
    <div
      class="panel-change-summary"
    >
      <time
        datetime=""
      >
        Last updated: 
        Awaiting first update
      </time>
      <span>
        No changes.
      </span>
    </div>
    <div
      class="monitor-item"
    >
      <div
        class="monitor-header"
      >
        <span
          class="monitor-name"
          title="rag-index-A"
        >
          rag-index-A
        </span>
        <span
          class="monitor-health "
        >
          HEALTHY
        </span>
      </div>
    </div>
    <div
      class="monitor-item"
    >
      <div
        class="monitor-header"
      >
        <span
          class="monitor-name"
          title="rag-index-B"
        >
          rag-index-B
        </span>
        <span
          class="monitor-health corrupt"
        >
          CORRUPT
        </span>
      </div>
    </div>
  </div>
</section>
`;

