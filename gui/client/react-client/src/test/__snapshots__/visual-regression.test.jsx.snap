exports[`visual regression harness > input area states render consistently in dark theme > input-generating-dark 1`] = `
<div
  class="input-area glass"
>
  <div
    class="input-wrapper"
  >
    <label
      class="sr-only"
      for="userInput"
    >
      Query message
    </label>
    <textarea
      id="userInput"
      placeholder="Ask anything about your documents..."
      rows="1"
      style="height: 0px;"
    />
    <button
      aria-label="Stop generation"
      class="send-message-button"
      data-tooltip="Stop generating this response"
      type="button"
    >
      <span
        aria-hidden="true"
      >
        ■
      </span>
    </button>
  </div>
  <div
    class="input-footer"
  >
    Powered by Native Ollama Embeddings & LanceDB • Local Execution Only
  </div>
</div>
`;

exports[`visual regression harness > input area states render consistently in dark theme > input-ready-dark 1`] = `
<div
  class="input-area glass"
>
  <div
    class="input-wrapper"
  >
    <label
      class="sr-only"
      for="userInput"
    >
      Query message
    </label>
    <textarea
      id="userInput"
      placeholder="Ask anything about your documents..."
      rows="1"
      style="height: 0px;"
    />
    <button
      aria-label="Send message"
      class="send-message-button"
      data-tooltip="Send your query to the AI"
      disabled=""
      type="button"
    >
      <svg
        aria-hidden="true"
        height="24"
        viewBox="0 0 24 24"
        width="24"
      >
        <path
          d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"
          fill="currentColor"
        />
      </svg>
    </button>
  </div>
  <div
    class="input-footer"
  >
    Powered by Native Ollama Embeddings & LanceDB • Local Execution Only
  </div>
</div>
`;

